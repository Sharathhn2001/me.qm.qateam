<!--++BOC REQ0032724 - Purchase Order SelectDialog Fragment for Insp Lot - by Sharath on 02/12/2025 -->
<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
>
    <TableSelectDialog
        id="valueHelpDialogPO"
        title="Select Purchase Order"
        liveChange="onPOSearch"
        confirm="onPOSelect"
        cancel="onPOCancel"
        noDataText="No Purchase Orders Found"
        items="{
            path : 'POModel>/results'
        }"
    >
        <columns>
            <!-- ++BOC INC0253045 - Added column width for better alignment and to avoid text wrapping - Sharath - 10/03/2026 -->
            <Column width="7rem">
                <header>
                    <Text text="PO No" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="PO Item" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="Plant" />
                </header>
            </Column>
            <!-- ++BOC INC0253045 - Added column width for better alignment and to avoid text wrapping - Sharath - 10/03/2026 -->
            <Column width="15rem">
                <header>
                    <Text text="Plant Name" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="Mat Group" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="Material#" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="Description" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="Batch" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="Vendor" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="Vendor Name" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="Quantity" />
                </header>
            </Column>
            <Column>
                <header>
                    <Text text="Unit" />
                </header>
            </Column>
            <!-- ++BOC INC0253045 - Added Formula column with fixed width for PO table - Sharath - 10/03/2026 -->
            <Column width="8rem">
                <header>
                    <Text text="Formula" />
                </header>
            </Column>
            <!-- ++EOC INC0253045 - Added Formula column with fixed width for PO table - Sharath - 10/03/2026 -->
        </columns>

        <items>
            <ColumnListItem>
                <cells>
                    <Text text="{POModel>Ebeln}" />
                    <Text text="{POModel>Ebelp}" />
                    <Text text="{POModel>Werks}" />
                    <Text text="{POModel>Werks_Name}" />
                    <Text text="{POModel>Matkl}" />
                    <Text text="{POModel>Matnr}" />
                    <Text text="{POModel>Maktx}" />
                    <Text text="{POModel>Charg}" />
                    <Text text="{POModel>Lifnr}" />
                    <Text text="{POModel>LifnrName}" />
                    <Text text="{POModel>Menge}" />
                    <Text text="{POModel>Meins}" />
                    <!-- ++BOC INC0253045 - Added Formula (SuchFeld) display in PO table - Sharath - 10/03/2026 -->
                    <Text
                        text="{POModel>SuchFeld}"
                        wrapping="true"
                    />
                    <!-- ++EOC INC0253045 - Added Formula (SuchFeld) display in PO table - Sharath - 10/03/2026 -->
                </cells>
            </ColumnListItem>
        </items>
    </TableSelectDialog>
</core:FragmentDefinition>
<!--++EOC REQ0032724 - Purchase Order SelectDialog Fragment for Insp Lot - by Sharath on 02/12/2025 -->
